<LoadPlugin python>
    Globals true
</LoadPlugin>
<Plugin python>
    ModulePath "/opt/puppet/collectd"
<%- python_rel = @facts['python_release'] || @facts['python3_release'] -%>
<%- if python_rel && python_rel.to_i < 3 -%>
    Encoding "utf-8"
<%- end -%>
    LogTraces true
    Interactive false
    Import "vmswap"
    <Module vmswap>
        processes "<%= @vmswap_process %>"
    </Module>
</Plugin>
